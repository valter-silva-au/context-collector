{
  "name": "context-collector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser extension that extracts conversations from web sessions as structured Markdown for AI agent context bootstrapping",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.30",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.287",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.2.4"
  }
}
